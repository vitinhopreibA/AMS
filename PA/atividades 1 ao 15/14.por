programa {
  funcao inicio() {

    real altura, altura_reque, degraus

    escreva("digite a altura de cada degral: ")
    leia(altura)
    escreva("digite a altura que vc deseja: ")
    leia(altura_reque)

    degraus=(altura_reque/altura)

    escreva("a quantidade de degraus é:",degraus)
    
  }
}
