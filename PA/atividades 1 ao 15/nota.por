programa {
  funcao inicio() {

    real nota1, nota2, nota3, nota4, media

    escreva("digite nota1")
    leia(nota1)
    escreva("digite nota2")
    leia(nota2)
    escreva("digite nota3")
    leia(nota3)
    escreva("digite nota4")
    leia(nota4)
    media=(nota1+nota2+nota3+nota4) /4

    escreva("media é:",media)
  }
}
