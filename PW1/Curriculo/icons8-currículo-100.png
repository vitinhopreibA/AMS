:root{
    /*MODO CLARO*/
    --cor-fundo: #ececec;
    --cor-header: #004d40;
    --cor-footer:#009688;
    --cor-texto:#222;
    --cor-branco:#fff;
    --cor-borda:#cecece;
    --cor-sombra:#ccc;
}

/*MODO ESCURO*/
.dark{
    --cor-fundo:#121212;
    --cor-header:#1f1f1f;
    --cor-footer:#2c2c2c;
    --cor-texto:#f1f1f1;
    --cor-branco:#1e1e1e;
    --cor-borda:#444;
    --cor-sombra:#000;
}

*{
    transition: all 0.5 ease;
}

body{
    background: var(--cor-fundo);
    color: var(--cor-texto);
}

header{
    background: var(--cor-texto);
}

h1{
    color: var(--cor-texto);
}

footer{
    background: var(--cor-footer);
    color: var(--cor-texto);
}

nav a{
    color: var(--cor-texto);
}

nav a:hover{
    color: var(--cor-footer);
}

Figure{
background: var(--cor-branco);
border: 1px solid var(--cor-borda);
box-shadow: 0 1px 2px var(--cor-sombra);
}

header{
width: 100%;
height: 50px;
background: var(--cor-header);
display: flex;
align-items: center;
justify-content: center;
position: relative;
}

#tema{
position:absolute;
right: 15px;
padding: 5px 10px;
border: none;
border-radius: 5px;
cursor:pointer;
background: var(--cor-footer);
color: var(--cor-branco);
font-size: 14px;
background: none;
font-size: 20px;
border: none;
cursor:pointer;
}